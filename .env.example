# --- Client (Vite — exposed to browser; never put secrets here) ---
# Optional: override Schwab proxy host (defaults to production Vercel deployment)
VITE_SCHWAB_API_BASE=https://therpghub.vercel.app

# --- Server (Vercel API routes / local dev only) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Schwab OAuth & market data
SCHWAB_CLIENT_ID=
SCHWAB_CLIENT_SECRET=
SCHWAB_REDIRECT_URI=

# Third-party APIs
ANTHROPIC_API_KEY=
OPENFIGI_API_KEY=

# Addepar (assignment check)
ADDEPAR_ASSIGNMENT_URL=
ADDEPAR_API_KEY=
ADDEPAR_API_SECRET=
ADDEPAR_API_TOKEN=
